rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper function for admin/curator roles
    function isSAHSUser() {
      return request.auth != null && 
        request.auth.token.email != null && (
        request.auth.token.email.lower().endsWith('@senoiahistory.com') || 
        request.auth.token.email.lower() == 'catnolan@senoiahistory.com' || 
        request.auth.token.email.lower() == 'jeremywarren@senoiahistory.com' ||
        (firestore.exists(/databases/sahs-archives/documents/user_roles/$(request.auth.token.email.lower())) && 
         firestore.get(/databases/sahs-archives/documents/user_roles/$(request.auth.token.email.lower())).data.role in ['admin', 'curator'])
      );
    }

    // archive_media folder: Everyone can read, only SAHS users can write
    match /archive_media/{allPaths=**} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // additional_media folder: Everyone can read, only SAHS users can write
    match /additional_media/{allPaths=**} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // accession_paperwork folder: Only SAHS users can read or write
    match /accession_paperwork/{allPaths=**} {
      allow read, write: if isSAHSUser();
    }

    // collections folder: Everyone can read, only SAHS users can write
    match /collections/{allPaths=**} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
